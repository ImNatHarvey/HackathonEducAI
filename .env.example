# === STUDY AURA MASTER CONFIG ===
# This file is used to configure all services in the repository.
# Run 'npm run setup' to generate the individual service .env files.

# --- 1. Primary AI (Required) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- 2. Supabase Config (Required for Frontend) ---
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- 3. AI Fallbacks (Highly Recommended) ---
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- 4. Web Extraction (Optional) ---
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
SUPADATA_API_KEY=your_supadata_api_key_here
TRANSCRIPTAPI_KEY=your_transcriptapi_key_here

# --- 5. Infrastructure (Defaults) ---
N8N_WEBHOOK_BASE_URL=http://localhost:5678
YOUTUBE_HELPER_URL=http://localhost:8787
