        "jsCode": "const input = $('Normalize Source Input').item.json;\nconst pages = $json.pages || $json.data?.pages || [];\nconst text = Array.isArray(pages)\n  ? pages.map(p => p.markdown || p.text || '').join('\\n\\n')\n  : ($json.text || $json.markdown || '');\nconst cleanedText = text\n  .replace(/!\\[[^\\]]*\\]\\([^)]+\\)/g, \" \")\n  .replace(/\\\\n/g, \"\\n\")\n  .replace(/\\n{3,}/g, \"\\n\\n\")\n  .replace(/[ \\t]{2,}/g, \" \")\n  .trim();\n\nconst ok = cleanedText && cleanedText.length > 120 && !$json.error;\n\nreturn [{\n  json: {\n    ...input,\n    extractedText: ok ? cleanedText : '',\n    status: ok ? 'ready' : 'failed',\n    statusMessage: ok ? 'PDF extracted using Mistral OCR.' : 'Could not extract this PDF. Try copied text or a clearer PDF link.',\n    parserProvider: ok ? 'mistral-ocr' : 'pdf-failed'\n  }\n}];"
