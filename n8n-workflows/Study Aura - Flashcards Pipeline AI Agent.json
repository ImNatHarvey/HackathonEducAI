    {
      "parameters": {
        "jsCode": "const raw = $json.output ?? \"\";\n\nconst cleaned = String(raw)\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nlet deck;\nlet fallback = false;\n\ntry {\n  deck = JSON.parse(cleaned);\n\n  if (!deck.title || !deck.cards || !Array.isArray(deck.cards)) {\n    throw new Error(\"Invalid deck format\");\n  }\n} catch (error) {\n  fallback = true;\n  deck = {\n    title: \"Study Aura Flashcards\",\n    cards: [\n      {\n        type: \"question\",\n        prompt: \"What is the best first step when reviewing a new topic?\",\n        answer: \"Break it into smaller parts\",\n        hint: \"Think of making the topic easier to handle.\",\n        explanation: \"Breaking a topic into smaller parts helps you understand and remember it more easily.\"\n      }\n    ]\n  };\n}\n\nconst normalizedCards = deck.cards.map((card) => ({\n  type: card.type === \"fill_blank\" ? \"fill_blank\" : \"question\",\n  prompt: String(card.prompt || \"Untitled flashcard\"),\n  answer: String(card.answer || \"No answer provided\"),\n  hint: String(card.hint || \"Think about the key idea.\"),\n  explanation: String(card.explanation || \"Review the related lesson content.\")\n}));\n\nreturn [\n  {\n    json: {\n      deck: {\n        title: String(deck.title || \"Study Aura Flashcards\"),\n        cards: normalizedCards\n      },\n      fallback,\n      provider: $json.provider || \"gemini\"\n    }\n  }\n];"
      },
