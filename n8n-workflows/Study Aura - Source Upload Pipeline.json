{
  "name": "Study Aura - Source Upload Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "study-aura-upload",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "source-upload-webhook",
      "name": "Source Upload Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [120, 260],
      "webhookId": "study-aura-upload"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{\n  {\n    \"success\": true,\n    \"lessonId\": \"lesson-\" + Date.now(),\n    \"message\": \"Source received by Study Aura.\",\n    \"lesson\": {\n      \"title\": $json.body.title || \"New Study Source\",\n      \"subtitle\": ($json.body.sourceType || \"source\") + \" source added. Ready for AI study tools.\",\n      \"progress\": 5\n    }\n  }\n}}",
        "options": {}
      },
      "id": "return-source-upload-response",
      "name": "Return Source Upload Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [420, 260]
    }
  ],
  "connections": {
    "Source Upload Webhook": {
      "main": [
        [
          {
            "node": "Return Source Upload Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
