      "id": "chat-agent-webhook",
      "name": "Chat Agent Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        80,
        420
      ],
      "webhookId": "study-aura-chat-agent"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "agent-prompt",
              "name": "prompt",
              "value": "={{\n\"You are Study Aura, an AI-powered educational tutor for students. Answer clearly, safely, and helpfully. Keep your answer concise but useful.\\n\\n\" +\n\"Current module/topic: \" + ($json.body.topic || \"General Study\") + \"\\n\" +\n\"User message: \" + ($json.body.message || \"\") + \"\\n\\n\" +\n\"Selected source context:\\n\" +\n(\n  Array.isArray($json.body.selectedSources) && $json.body.selectedSources.length > 0\n    ? $json.body.selectedSources.map((source, index) => {\n        return (index + 1) + \". \" + (source.title || \"Untitled Source\") + \" [\" + (source.type || \"source\") + \"]\\n\" +\n          \"Summary or content: \" + (source.summary || source.value || \"No summary provided.\");\n      }).join(\"\\n\\n\")\n    : \"No selected sources were provided. Use the topic and user message only.\"\n) +\n\"\\n\\nInstructions:\\n\" +\n\"- Prioritize selected source context when available.\\n\" +\n\"- If source context is missing, answer based on the topic.\\n\" +\n\"- Keep the answer student-friendly.\\n\" +\n\"- Use bullets when helpful.\\n\" +\n\"- Do not mention internal workflow details.\\n\" +\n\"- If the request is unsafe, refuse briefly and redirect to safe learning.\"\n}}",
              "type": "string"
            },
            {
              "id": "topic",
              "name": "topic",
              "value": "={{$json.body.topic || \"General Study\"}}",
              "type": "string"
            },
            {
              "id": "message",
              "name": "message",
              "value": "={{$json.body.message || \"\"}}",
              "type": "string"
            },
            {
              "id": "module-id",
              "name": "moduleId",
              "value": "={{$json.body.moduleId || \"demo-module\"}}",
              "type": "string"
            },
            {
              "id": "user-id",
              "name": "userId",
              "value": "={{$json.body.userId || \"demo-user\"}}",
              "type": "string"
            },
            {
              "id": "selected-source-count",
              "name": "selectedSourceCount",
              "value": "={{Array.isArray($json.body.selectedSources) ? $json.body.selectedSources.length : 0}}",
              "type": "number"
            }
          ]
        },
        "options": {}
      },
